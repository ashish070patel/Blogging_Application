<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog</title>
</head>
<body>
    <%- include("./partials/nav") %>
    <div class="container mt-4">
        <h1> <%= blog.title %> </h1>
        <img src="<%= blog.coverImageURL %>" width="700px"/>
        <pre class="mt-3"> <%= blog.body %> </pre>
    </div>
    <div class="container mt-4">
        <div>
            <img src="<%= blog.createdBy.profileImage %>" width="30px"/>
            <%= blog.createdBy.fullName %>
        </div>
        <% if (locals.user && locals.user._id.toString() === blog.createdBy._id.toString()) { %>
            <form action="/blog/delete/<%= blog._id %>" method="POST" class="ms-4 mb-0" onsubmit="return confirm('Are you sure you want to delete this blog? This action cannot be undone.');">
                <button type="submit" class="btn btn-sm btn-danger">Delete Blog</button>
            </form>
        <% } %>
    </div>

    <div class="container mt-3">
        <h1>Comment (<%= comment.length %>)</h1>
        <% if (locals.user) { %>
            <form action="/blog/comment/<%= blog._id %>" method="post">
                <div class="mb-3">
                    <input type="text" name="content" class="form-control" placeholder="Enter Your Comment">
                    <button class="btn btn-sm btn-primary" type="submit">Add</button>
                </div>
            </form>
        <% } %>
        <div class="mt-3">
            <% comment.forEach(comment => { %>
                <div>
                    <img src="<%= comment.createdBy.profileImage %>" width="30px"/>
                    <%= comment.createdBy.fullName %>
                    <pre><%= comment.comment %></pre>
                </div>
            <% }) %>
        </div>
    </div>
    <%- include("./partials/script") %>
</body>
</html>